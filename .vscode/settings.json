{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.rulers": [100],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit"
  },
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact", "vue"],
  "stylelint.validate": ["css", "postcss", "vue"],
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "tailwindCSS.includeLanguages": {
    "vue": "html",
    "postcss": "css"
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "cSpell.enabled": true,
  "cSpell.useGitignore": true,
  "cSpell.spellCheckOnlyWorkspaceFiles": true,
  "cSpell.ignorePaths": [
    ".git",
    "**/.git",
    "node_modules",
    "**/node_modules",
    ".nuxt",
    "**/.nuxt",
    ".output",
    "**/.output",
    "dist",
    "**/dist",
    "coverage",
    "**/coverage",
    ".turbo",
    "**/.turbo",
    ".playwright-mcp",
    ".pnpm-store",
    "packages/db/src/generated",
    "pnpm-lock.yaml",
    "*.log"
  ],
  "files.exclude": {
    "**/.nuxt": true,
    "**/.output": true,
    "**/.turbo": true,
    "**/coverage": true,
    "**/dist": true,
    "**/node_modules": true,
    "packages/db/src/generated": true
  },
  "search.exclude": {
    "**/.nuxt": true,
    "**/.output": true,
    "**/.turbo": true,
    "**/coverage": true,
    "**/dist": true,
    "**/node_modules": true,
    "packages/db/src/generated": true
  },
  "css.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
